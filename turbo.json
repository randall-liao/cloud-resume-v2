{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"]
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "lint": {
      "dependsOn": [],
      "outputs": []
    },
    "plan": {
      "dependsOn": [],
      "outputs": []
    },
    "apply": {
      "dependsOn": ["plan"],
      "outputs": []
    },
    "fmt": {
      "dependsOn": [],
      "outputs": []
    }
  }
}
