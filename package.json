{
  "name": "cloud-resume-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "infra/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @cloud-resume-v2/web --",
    "build:packages": "npm run build --workspace @cloud-resume-v2/contracts && npm run build --workspace @cloud-resume-v2/frontend-core",
    "build:web": "npm run build --workspace @cloud-resume-v2/web",
    "docs:validate": "node scripts/validate-docs.mjs",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "preview": "npm run preview --workspace @cloud-resume-v2/web --",
    "test": "turbo run test && python3 scripts/test_agents_scripts.py",
    "validate": "npm run docs:validate && python3 scripts/lint_agents.py && npm run lint && npm run build && npm run test && bash scripts/validate-dist.sh apps/web/dist"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "typescript": "^5.0.2",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "packageManager": "npm@10.5.0"
}
