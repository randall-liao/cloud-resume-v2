# =============================================================================
# .env.example — Reserved Environment Variable Template
# =============================================================================
# The current app does not require environment variables to build or run.
# This file is kept as Phase 1 scaffold for the planned visitor-counter API.
#
# If that API is implemented later, copy this file to .env.local and fill in the
# endpoint value. Vite exposes only variables prefixed with VITE_ to the browser.
# Never place AWS credentials, private keys, or other secrets in VITE_ vars.
# =============================================================================

# Planned visitor-counter API (future work)
# Format: https://<api-id>.execute-api.<region>.amazonaws.com/<stage>/count
VITE_VISITOR_API_URL=https://YOUR_API_ID.execute-api.us-east-1.amazonaws.com/prod/count
